        </mxCell>

        <mxCell id="P2" value="&lt;b&gt;Problem 2: Uniform credit&lt;/b&gt;&lt;br&gt;Same sequence-level A for all t&lt;br&gt;Ignores autoregressive causality&lt;br&gt;→ &lt;font color=&quot;#b85450&quot;&gt;misaligned advantages in GRPO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
